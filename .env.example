# ─────────────────────────────────────────────────────────────────────────────
# AI Intelligence Hub - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and customize values for your local environment.
# All values below are defaults suitable for docker-compose local development.

# ------------ Service Configuration ------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_GRPC_PORT=50051
SERVICE_REQUEST_TIMEOUT_SECONDS=10
SERVICE_ENVIRONMENT=development

# ------------ PostgreSQL (pgvector) ------------------------------------------
POSTGRES_URL=postgresql+asyncpg://ai_hub:ai_hub@postgres:5432/ai_intelligence_hub
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20
POSTGRES_EF_SEARCH=100

# Alembic uses sync driver for migrations
SQLALCHEMY_DATABASE_URL=postgresql://ai_hub:ai_hub@postgres:5432/ai_intelligence_hub

# ---------- Redis ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_DEFAULT_TTL=3600

# ------------ Amazon Bedrock (via Localstack in dev ) ------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION_NAME=us-east-1
BEDROCK_TIMEOUT_SECONDS=5

# AWS Credentials (Localstack in dev , real credentials in prod)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# ---------- TorchServe (DistilBERT Sidecar) ----------------------------------
TORCHSERVE_URL=http://torchserve:8080
TORCHSERVE_MODEL_NAME=distilbert-ticket-classifier
TORCHSERVE_TIMEOUT_SECONDS=2.0
TORCHSERVE_BATCH_SEIZE=32
TORCHSERVE_BATCH_WINDOW_MS=50

# --------- Embedding Service -------------------------------------------------
EMBEDDING_URL=http://torchserve:8080
EMBEDDING_TIMEOUT_SECONDS=2.0
EMBEDDING_DIMENSION=1024

# ------------- Kafka (Redpanda in dev) ---------------------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC=enriched-events
KAFKA_GROUP_ID=ai-intelligence-hub-embedding
KAFKA_DEAD_LETTER_TOPIC=enriched-events-dlq
KAFKA_MAX_RETRIES=5

# ------------- LLM Gateway ---------------------------------------------------
LLM_GATEWAY_MAX_INFLIGHT=20
LLM_GATEWAY_RETRY_MAX_ATTEMPTS=3
LLM_GATEWAY_RETRY_BASE_DELAY_MS=500
LLM_GATEWAY_CACHE_TTL=3600

# ------------- Circuit Breaker -----------------------------------------------
CIRCUIT_BREAKER_FAILURE_THRESHOLD=0.5
CIRCUIT_BREAKER_WINDOW_SECONDS=60.0
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0
CIRCUIT_BREAKER_MIN_CALLS=5

# ------------- Cost Circuit Breaker -----------------------------------------------
COST_BREAKER_DAILY_THRESHOLD=1000000

# ------------- Rate Limiting --------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ------------- Guardrails ----------------------------------------------------
GUARDRAIL_MAX_QUERY_LENGTH=4000
GUARDRAIL_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# ------------- Feature Flags -------------------------------------------------
FEATURE_SUMMARIZATION_ENABLED=true
FEATURE_RAG_ENABLED=true
FEATURE_TRIAGE_ENABLED=true

# ------------- Observability -------------------------------------------------
OBSERVABILITY_LANGSMITH_PROJECT=ai-intelligence-hub
OBSERVABILITY_CLOUDWATCH_NAMESPACE=AIIntelligenceHub
OBSERVABILITY_METRICS_INTERVAL_SECONDS=60
OBSERVABILITY_CONSUMER_LAG_ALERT_SECONDS=60
OBSERVABILITY_BEDROCK_THROTTLE_THRESHOLD=0.1
OBSERVABILITY_COST_ALERT_PERCENTAGE=0.8

# ---------- Langsmith (optional, for tracing) --------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-intelligence-hub